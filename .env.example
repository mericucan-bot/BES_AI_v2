# TCMB EVDS API Key
# Almak icin: https://evds2.tcmb.gov.tr/ → Uye ol → Profil → API Anahtari
TCMB_API_KEY=your_8_character_key_here

# E-posta Bildirimi (opsiyonel)
# Gmail App Password almak icin: Google Account → Security → 2FA → App Passwords
EMAIL_SENDER=senin@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECIPIENTS=alici1@email.com,alici2@email.com

# Telegram uyarilari (opsiyonel) — notable/action aylarda anlik mesaj
# @BotFather -> TELEGRAM_BOT_TOKEN; bota /start + getUpdates -> TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token
TELEGRAM_CHAT_ID=123456789
